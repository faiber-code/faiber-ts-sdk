{
  "compilerOptions": {
    "target": "ES2022", "module": "NodeNext", "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"], "declaration": true, "declarationMap": true,
    "sourceMap": true, "strict": true, "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true, "verbatimModuleSyntax": true, "isolatedModules": true,
    "skipLibCheck": true, "forceConsistentCasingInFileNames": true, "composite": true,
    "baseUrl": ".", "ignoreDeprecations": "6.0",
    "paths": {
      "@faiber/sdk-core": ["packages/core/src/index.ts"],
      "@faiber/infera-idp": ["packages/idp/src/index.ts"],
      "@faiber/infera-profile": ["packages/profile/src/index.ts"],
      "@faiber/infera-modules": ["packages/modules/src/index.ts"],
      "@faiber/infera-asset": ["packages/asset/src/index.ts"],
      "@faiber/infera-payment": ["packages/payment/src/index.ts"],
      "@faiber/infera-messenger": ["packages/messenger/src/index.ts"],
      "@faiber/infera-crm": ["packages/crm/src/index.ts"],
      "@faiber/infera-lms": ["packages/lms/src/index.ts"],
      "@faiber/infera-reservation": ["packages/reservation/src/index.ts"],
      "@faiber/infera-session": ["packages/session/src/index.ts"],
      "@faiber/infera-version": ["packages/version/src/index.ts"],
      "@faiber/infera-flow": ["packages/flow/src/index.ts"]
    }
  }
}
